# ░░  SECTION 2 — GRAMMAR PATTERNS (25 categories)
# ════════════════════════════════════════════════════════════════

def _build_grammar_patterns():
    P = []

    # ── 01. ARTICLES ─────────────────────────────────────────
    P += [
        (r"\ba\s+([aeiouAEIOU]\w*)",
         r"an \1",
         "Article: 'a' before vowel → 'an'"),
        (r"\ban\s+([b-df-hj-np-tv-zB-DF-HJ-NP-TV-Z])(\w*)",
         r"a \1\2",
         "Article: 'an' before consonant → 'a'"),
        (r"\bthe\s+the\b",          "the",   "Article: duplicate 'the'"),
        (r"\ba\s+a\b",              "a",     "Article: duplicate 'a'"),
        (r"\ban\s+an\b",            "an",    "Article: duplicate 'an'"),
        (r"\bthe\s+(SVC-F|ADV|OCR|PDF|GPS|AV|AI|ML|LLM)\b",
         r"the \1",
         "Article: keep 'the' before acronym"),
    ]

    # ── 02. SVA — 1ST PERSON ─────────────────────────────────
    P += [
        (r"(?i)\bI\s+does\b",              "I do",        "SVA 1st: I does → I do"),
        (r"(?i)\bI\s+has\b",               "I have",      "SVA 1st: I has → I have"),
        (r"(?i)\bI\s+is\b",                "I am",        "SVA 1st: I is → I am"),
        (r"(?i)\bI\s+are\b",               "I am",        "SVA 1st: I are → I am"),
        (r"(?i)\bI\s+was\s+not\s+did\b",   "I did not",   "SVA 1st: I was not did → I did not"),
        (r"(?i)\bI\s+doesn't\b",           "I don't",     "SVA 1st: I doesn't → I don't"),
        (r"(?i)\bI\s+don't\s+likes\b",     "I don't like","SVA 1st: don't likes → don't like"),
        (r"(?i)\bI\s+was\s+be\b",          "I was",       "SVA 1st: I was be → I was"),
        (r"(?i)\bI\s+been\b",              "I have been", "SVA 1st: I been → I have been"),
        (r"(?i)\bI\s+go\s+to\s+went\b",    "I went to",   "SVA 1st: I go to went → I went to"),
        (r"(?i)\bam\s+not\s+be\b",         "am not",      "SVA 1st: am not be → am not"),
        (r"(?i)\bI\s+having\b",            "I have",      "SVA 1st: I having → I have"),
        (r"(?i)\bI\s+wanting\b",           "I want",      "SVA 1st: I wanting → I want"),
        (r"(?i)\bI\s+knowing\b",           "I know",      "SVA 1st: I knowing → I know"),
        (r"(?i)\bI\s+liking\b",            "I like",      "SVA 1st: I liking → I like"),
        (r"(?i)\bI\s+needing\b",           "I need",      "SVA 1st: I needing → I need"),
    ]

    # ── 03. SVA — 2ND / PLURAL ───────────────────────────────
    for subj in ["we","you","they"]:
        for wrong, right, verb in [
            ("does","do","does→do"),("has","have","has→have"),
            ("is","are","is→are"),("was","were","was→were"),
            ("needs","need","needs→need"),("wants","want","wants→want"),
            ("goes","go","goes→go"),("runs","run","runs→run"),
            ("makes","make","makes→make"),("gets","get","gets→get"),
            ("comes","come","comes→come"),("takes","take","takes→take"),
            ("says","say","says→say"),("sees","see","sees→see"),
            ("knows","know","knows→know"),("thinks","think","thinks→think"),
            ("works","work","works→work"),("looks","look","looks→look"),
            ("feels","feel","feels→feel"),("lives","live","lives→live"),
            ("plays","play","plays→play"),("writes","write","writes→write"),
            ("helps","help","helps→help"),("shows","show","shows→show"),
            ("turns","turn","turns→turn"),("starts","start","starts→start"),
            ("stops","stop","stops→stop"),("uses","use","uses→use"),
            ("allows","allow","allows→allow"),("means","mean","means→mean"),
            ("includes","include","includes→include"),
            ("becomes","become","becomes→become"),
            ("requires","require","requires→require"),
            ("remains","remain","remains→remain"),
            ("leads","lead","leads→lead"),("affects","affect","affects→affect"),
            ("applies","apply","applies→apply"),
            ("causes","cause","causes→cause"),
            ("changes","change","changes→change"),
            ("appears","appear","appears→appear"),
        ]:
            P.append((
                rf"(?i)\b{subj}\s+{wrong}\b",
                f"{subj} {right}",
                f"SVA plural: {subj} {verb}"
