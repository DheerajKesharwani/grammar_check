    # ── 24. RELATIVE CLAUSES ─────────────────────────────────
    P += [
        (r"(?i)\bthe\s+(\w+)\s+which\s+is\s+(\w+ing)\b",
         lambda m: f"the {m.group(1)} that is {m.group(2)}",
         "RelClause: which is Ving → that is Ving (defining)"),
        (r"(?i)\bthe\s+person\s+which\b",      "the person who",   "RelClause: person which → who"),
