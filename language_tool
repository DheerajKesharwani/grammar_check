            ("write","writes"),("speak","speaks"),("help","helps"),
            ("show","shows"),("turn","turns"),("start","starts"),
            ("stop","stops"),("use","uses"),("allow","allows"),
            ("mean","means"),("include","includes"),("become","becomes"),
            ("contain","contains"),("provide","provides"),("follow","follows"),
            ("remain","remains"),("require","requires"),("represent","represents"),
            ("describe","describes"),("cause","causes"),("involve","involves"),
            ("change","changes"),("appear","appears"),("depend","depends"),
