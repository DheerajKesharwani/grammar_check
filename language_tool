def interactive(use_slm: bool):
    print("\n" + "="*72)
    print("  WAYMO CAPTION CHECKER — COMPREHENSIVE GRAMMAR ANALYSIS")
    print("  S1:LT | S2:Rule | S3:Diag | S4:Pleonasm | S5:Overuse")
    print("  S6:TF-IDF | S7:ML-dedup | S8:CoEdit SLM | S9:LowConf")
    print("="*72)
    print("\n  1. PDF file  2. Text file  3. Type manually  0. Exit\n")

    choice = input("  Choice: ").strip()
    if choice == "0": sys.exit(0)
    elif choice == "1":
        fp = input("  PDF path: ").strip().strip('"')
        text = read_pdf(fp); source = fp
    elif choice == "2":
        fp = input("  TXT path: ").strip().strip('"')
        text = read_txt(fp); source = fp
    elif choice == "3":
        text = read_manual(); source = "manual"
    else:
        print("Invalid."); sys.exit(1)

    print("\n⚙️  Running full 9-section analysis...")
    report, _ = run_and_report(text, source=source, use_slm=use_slm)
    print(report)

    if input("\n  Save report? (y/n): ").strip().lower() == "y":
        out = input("  Filename (Enter=auto): ").strip() or "waymo_report.txt"
        with open(out, "w", encoding="utf-8") as f:
            f.write(report)
        print(f"  Saved: {out}")


