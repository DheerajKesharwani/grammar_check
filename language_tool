# ░░  SECTION 9 — COMBINED CHECKER ENGINE
# ════════════════════════════════════════════════════════════════

class WaymoCapChecker:

    def __init__(self, use_slm: bool = True):
        self.grammar = GrammarChecker()
        self.lc      = LowConfidenceChecker()
        self.slm     = SLMCorrector() if use_slm else None

    def analyze(self, text: str, source_file: str = "manual input") -> CombinedResult:
        result = CombinedResult(original_text=text, source_file=source_file)

        # ── Pass 1: Grammar rules ─────────────────────────────
        g_issues, g_corrected     = self.grammar.check(text)
        result.grammar_issues     = g_issues
        result.grammar_corrected  = g_corrected

        # ── Pass 2: Low confidence on grammar-corrected text ──
        lc_issues, lc_corrected, cats = self.lc.check(g_corrected)
        result.lc_issues          = lc_issues
        result.lc_corrected       = lc_corrected
        result.lc_categories_hit  = cats

        # ── Pass 3: SLM contextual rewrite ───────────────────
        if self.slm and self.slm.available:
            result.slm_corrected  = self.slm.correct(lc_corrected)
            result.slm_available  = True
            result.final_text     = result.slm_corrected
        else:
            result.slm_corrected  = lc_corrected
            result.slm_available  = False
            result.final_text     = lc_corrected

        result.passed = (len(g_issues) == 0 and len(lc_issues) == 0)
        return result

    def report(self, result: CombinedResult) -> str:
        W = 74
        lines = []
        lines.append("=" * W)
        lines.append("  WAYMO CAPTION CHECKER v2 — FULL REPORT")
        lines.append("  Pass 1: Grammar Rules (25 categories, 600+ patterns)")
        lines.append("  Pass 2: Low Confidence Words (20 categories, 150+ patterns)")
        lines.append("  Pass 3: SLM Coedit (grammarly/coedit-large)")
        lines.append("=" * W)
        lines.append(f"\n  Source   : {result.source_file}")
        lines.append(f"  Status   : {result.summary()}")
        lines.append(f"  Grammar  : {len(result.grammar_issues)} issue(s) found")
        lines.append(f"  Low Conf : {len(result.lc_issues)} issue(s) found")
        lines.append(f"  SLM      : {'✅ Applied' if result.slm_available else '⚠️  Not available (pip install transformers torch)'}")
        if result.lc_categories_hit:
            lines.append(f"  LC Cats  : {', '.join(result.lc_categories_hit)}")

        # Grammar section
        if result.grammar_issues:
            lines.append("\n" + "─" * W)
            lines.append("  SECTION A — GRAMMAR ISSUES (Rule-Based)")
            lines.append("─" * W)
            for i, issue in enumerate(result.grammar_issues, 1):
                lines.append(f"\n  #{i}  {issue.label}")
                lines.append(f"       Found    : '{issue.original}'")
                lines.append(f"       Fix      : → '{issue.corrected}'")
                if issue.sentence:
                    lines.append(f"       Sentence : {issue.sentence[:85]}")
        else:
            lines.append("\n  SECTION A — GRAMMAR: ✅ No issues found")

        # Low confidence section
        if result.lc_issues:
            lines.append("\n" + "─" * W)
            lines.append("  SECTION B — LOW CONFIDENCE WORDS")
            lines.append("─" * W)
            for i, issue in enumerate(result.lc_issues, 1):
                fix = f"→ '{issue.suggestion}'" if issue.suggestion else "→ REMOVE"
                lines.append(f"\n  #{i}  [{issue.category}]")
                lines.append(f"       Found    : '{issue.word_found}'")
                lines.append(f"       Reason   : {issue.reason}")
                lines.append(f"       Fix      : {fix}")
                lines.append(f"       Sentence : {issue.sentence[:85]}")
        else:
            lines.append("\n  SECTION B — LOW CONFIDENCE: ✅ No issues found")

        # Before / After
        lines.append("\n" + "─" * W)
        trunc = lambda s, n: s[:n] + ("..." if len(s) > n else "")
        lines.append("  ORIGINAL:")
        lines.append(f"  {trunc(result.original_text, 400)}")
        lines.append("\n  AFTER PASS 1 — Grammar fixed:")
        lines.append(f"  {trunc(result.grammar_corrected, 400)}")
        lines.append("\n  AFTER PASS 2 — Low confidence fixed:")
        lines.append(f"  {trunc(result.lc_corrected, 400)}")
        if result.slm_available:
            lines.append("\n  AFTER PASS 3 — SLM contextual rewrite:")
            lines.append(f"  {trunc(result.slm_corrected, 400)}")
        lines.append("\n  FINAL TEXT:")
        lines.append(f"  {trunc(result.final_text, 400)}")
        lines.append("=" * W)
        return "\n".join(lines)

    def save_report(self, result: CombinedResult, output_path: str = None):
        if output_path is None:
            base = os.path.basename(os.path.splitext(result.source_file)[0])
            output_path = f"{base}_waymo_report.txt"
        content = (
            self.report(result)
            + "\n\n" + "=" * 74
            + "\n  FULL FINAL CORRECTED TEXT\n"
            + "=" * 74
            + f"\n\n{result.final_text}\n"
        )
        with open(output_path, "w", encoding="utf-8") as f:
            f.write(content)
        print(f"\n💾 Report saved: {output_path}")
        return output_path


