@dataclass
class GrammarIssue:
    original:  str
    corrected: str
    label:     str
    position:  int
    sentence:  str

@dataclass
class LCIssue:
    word_found: str
    category:   str
    reason:     str
    suggestion: str
    position:   int
    sentence:   str

@dataclass
class CombinedResult:
    original_text:     str
    source_file:       str = "manual input"
    grammar_issues:    List[GrammarIssue] = field(default_factory=list)
    grammar_corrected: str = ""
    lc_issues:         List[LCIssue]     = field(default_factory=list)
    lc_corrected:      str = ""
    lc_categories_hit: List[str]         = field(default_factory=list)
    slm_corrected:     str = ""
    slm_available:     bool = False
    final_text:        str = ""
    passed:            bool = False

    def summary(self) -> str:
        g = len(self.grammar_issues)
        l = len(self.lc_issues)
        if g == 0 and l == 0:
            return "✅ FULLY PASSED — No grammar or low confidence issues found"
        parts = []
        if g: parts.append(f"{g} grammar issue(s)")
        if l: parts.append(f"{l} low confidence issue(s)")
        return "❌ FAILED — " + " + ".join(parts)


