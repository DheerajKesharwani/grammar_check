# ░░  SECTION 8 — SLM COEDIT CORRECTOR
# ════════════════════════════════════════════════════════════════

class SLMCorrector:
    """
    Uses grammarly/coedit-large for contextual grammar correction.
    Falls back gracefully if model not installed.

    Install: pip install transformers torch sentencepiece
    """

    MODEL_NAME = "grammarly/coedit-large"

    def __init__(self):
        self.available = False
        self.tokenizer = None
        self.model     = None
        self._try_load()

    def _try_load(self):
        try:
            from transformers import AutoTokenizer, AutoModelForSeq2SeqLM
            print("⚙️  Loading SLM (grammarly/coedit-large)... ", end="", flush=True)
            self.tokenizer = AutoTokenizer.from_pretrained(self.MODEL_NAME)
            self.model     = AutoModelForSeq2SeqLM.from_pretrained(self.MODEL_NAME)
            self.available = True
            print("✅ Loaded")
        except Exception as e:
            print(f"\n⚠️  SLM not available ({type(e).__name__})")
            print("   To enable: pip install transformers torch sentencepiece")
            print("   Skipping SLM pass — rule-based corrections still applied.\n")
            self.available = False

    def correct(self, text: str) -> str:
        if not self.available:
            return text

        # Split into sentences for better SLM performance
        sentences = re.split(r'(?<=[.!?])\s+', text.strip())
        corrected_parts = []

        for sent in sentences:
            if not sent.strip():
                continue
            try:
                prompt = f"Fix grammatical errors in this sentence: {sent}"
                inputs = self.tokenizer(
                    prompt,
                    return_tensors="pt",
                    max_length=256,
                    truncation=True
                )
                outputs = self.model.generate(
                    **inputs,
                    max_length=256,
                    num_beams=4,
                    early_stopping=True,
                    no_repeat_ngram_size=2,
                )
                fixed = self.tokenizer.decode(outputs[0], skip_special_tokens=True)
                corrected_parts.append(fixed)
            except Exception:
                corrected_parts.append(sent)  # fallback: keep original

        return " ".join(corrected_parts)


