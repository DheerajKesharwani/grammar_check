# 8. CoEdit SLM
# ═══════════════════════════════════════════════════════════════

def coedit_correct(text: str) -> Tuple[str, List[Tuple[str,str]], bool]:
    try:
        from transformers import AutoTokenizer, AutoModelForSeq2SeqLM
        import torch
    except ImportError:
        return text, [], False

    model_path = _COEDIT_ID
    if os.path.isdir(_BUNDLED_COEDIT):
        model_path = _BUNDLED_COEDIT
    elif os.path.isdir(_LOCAL_COEDIT):
        snaps = sorted(d for d in os.listdir(_LOCAL_COEDIT)
                       if os.path.isdir(os.path.join(_LOCAL_COEDIT, d)))
        if snaps:
            model_path = os.path.join(_LOCAL_COEDIT, snaps[-1])

    try:
        tok = AutoTokenizer.from_pretrained(model_path)
        mdl = AutoModelForSeq2SeqLM.from_pretrained(model_path)
    except Exception as e:
        return text, [], False

    device = "cuda" if torch.cuda.is_available() else "cpu"
    mdl.to(device)
    sents = split_sentences(text) or [text]
    corrected, pairs = [], []
    for sent in sents:
        inp = tok(f"Fix the grammar: {sent}", return_tensors="pt",
                  truncation=True, max_length=512).to(device)
        with torch.no_grad():
            ids = mdl.generate(**inp, max_new_tokens=256, num_beams=4, early_stopping=True)
        fixed = tok.decode(ids[0], skip_special_tokens=True).strip()
        corrected.append(fixed)
        if fixed.lower() != sent.lower():
            pairs.append((sent, fixed))
    return " ".join(corrected), pairs, True


