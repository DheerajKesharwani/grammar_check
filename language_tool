# ═══════════════════════════════════════════════════════════════
# 4. UTILITY FUNCTIONS
# ═══════════════════════════════════════════════════════════════

def split_sentences(text: str) -> List[str]:
    if not text or not text.strip():
        return []
    text = re.sub(r"\s+", " ", text.strip())
    text = re.sub(r"(\d)\.(\d)", r"\1<DEC>\2", text)
    rough = re.split(r"(?<=[.!?])\s+(?=[A-Z])", text)
    sents = []
    for s in rough:
        s = s.replace("<DEC>", ".").strip()
        if not s:
            continue
        last = s.split()[-1].rstrip(".") if s.split() else ""
        if sents and last.lower() in _ABBREV:
            sents[-1] += " " + s
        else:
            sents.append(s)
    return sents


def fix_caps(text: str) -> str:
    return re.sub(r"(^|[.!?]\s+)([a-z])",
                  lambda m: m.group(1)+m.group(2).upper(), text)


def find_pleonasms(text: str) -> List[Tuple[str,str]]:
    found, low = [], text.lower()
    for pat, better in PLEONASMS.items():
        for m in re.finditer(pat, low):
            found.append((m.group(), better))
    return found


def find_overused(text: str, top: int = 10) -> List[Tuple[str,int]]:
    words  = re.findall(r"\b[a-z]{3,}\b", text.lower())
    counts = Counter(w for w in words if w not in _STOP)
    return [(w,c) for w,c in counts.most_common(top) if c > 2]


def tfidf_dupes(sents: List[str], thresh: float = 0.45) -> List[Tuple[float,str,str]]:
    if len(sents) < 2:
        return []
    try:
        from sklearn.feature_extraction.text import TfidfVectorizer
        from sklearn.metrics.pairwise import cosine_similarity
        X   = TfidfVectorizer().fit_transform(sents)
        sim = cosine_similarity(X)
        out = []
        for i in range(len(sents)):
            for j in range(i+1, len(sents)):
                if sim[i][j] >= thresh:
                    out.append((float(sim[i][j]), sents[i], sents[j]))
        return sorted(out, reverse=True)
    except ImportError:
        return []


def check_spelling(text: str) -> List[Dict]:
    try:
        from spellchecker import SpellChecker
    except ImportError:
        return []
    spell  = SpellChecker()
    issues, seen = [], set()
    for w in re.findall(r"\b[A-Za-z][A-Za-z']+\b", text):
        low = w.lower()
        if low in seen or w[0].isupper():
            continue
        if low in spell:
            continue
        seen.add(low)
        issues.append({"type":"spelling","bad":w,
                       "suggestion":spell.correction(low) or "(no suggestion)"})
    return issues


def check_spacy(text: str) -> List[Dict]:
    try:
        import spacy; nlp = spacy.load("en_core_web_sm")
    except Exception:
        return []
    issues = []
    for tok in nlp(text):
        if tok.dep_ == "nsubj" and tok.lower_ in {"he","she","it"}:
            head = tok.head
            if head.pos_ == "VERB" and head.tag_ == "VB":
                issues.append({"type":"SVA (spaCy)",
                               "bad":f"{tok.text} {head.text}",
                               "suggestion":f"{tok.text} {head.lemma_}s"})
    return issues


def ml_dedup(text: str, thresh: float = 0.82) -> Tuple[str, List[str]]:
    sents = split_sentences(text)
    if len(sents) <= 1:
        return text, []
    try:
        from sentence_transformers import SentenceTransformer, util
        mp  = _LOCAL_STMODEL if os.path.isdir(_LOCAL_STMODEL) else "all-MiniLM-L6-v2"
        mdl = SentenceTransformer(mp)
        emb = mdl.encode(sents, convert_to_tensor=True, show_progress_bar=False)
        kept, removed = [], []
        for i, s in enumerate(sents):
            if any(float(util.cos_sim(emb[i], emb[j])) > thresh for j in kept):
                removed.append(s)
            else:
                kept.append(i)
        return " ".join(sents[i] for i in kept), removed
    except Exception:
        return text, []


def languagetool_correct(text: str) -> Tuple[str, List, Optional[Exception]]:
    try:
        import language_tool_python, time
    except ImportError:
        return text, [], Exception("language_tool_python not installed.\n    Install: pip install language-tool-python")
    lt_jar = os.path.join(_LT_JAR, "languagetool-server.jar")
    last_err = None
    for attempt in range(1, 4):
        try:
            lt = (language_tool_python.LanguageTool("en-US")
                  if os.path.isfile(lt_jar)
                  else language_tool_python.LanguageToolPublicAPI("en-US"))
            matches  = lt.check(text)
            filtered = [m for m in matches
                        if getattr(m,"rule_id",getattr(m,"ruleId","")) not in _SKIP_RULES]
            corrected = language_tool_python.utils.correct(text, filtered)
            lt.close()
            return corrected, filtered, None
        except Exception as e:
            last_err = e
            msg = str(e).lower()
            if ("rate limit" in msg or "429" in msg or "too many" in msg) and attempt < 3:
                wait = 30 * attempt
                print(f"  Rate limit — waiting {wait}s ...")
                __import__("time").sleep(wait)
            else:
                break
    return text, [], last_err


# ═══════════════════════════════════════════════════════════════
# 5. RULE-BASED FIXER
# ═══════════════════════════════════════════════════════════════

def rule_based_fixer(text: str) -> Tuple[str, int, List[str]]:
    if not text or not text.strip():
        return text, 0, []
    changes, n = [], 0

    # OCR/spelling word fixes
    for pat, repl in _OCR_FIXES.items():
        new, k = re.subn(pat, repl, text, flags=re.IGNORECASE)
        if k:
            changes.append(f"[OCR/Spell] {pat!r} → '{repl}' ({k}×)")
            text, n = new, n + k

    # Grammar patterns
    for pat, repl, label in _GRAMMAR_PATTERNS:
        try:
            new, k = re.subn(pat, repl, text)
            if k:
                changes.append(f"[{label}] ({k}×)")
                text, n = new, n + k
        except Exception:
            pass

    # Contractions
    for m in list(re.finditer(r"\b([A-Za-z]+)\b", text)):
        low = m.group(1).lower()
        if low in CONTRACTIONS and not m.group(1)[0].isupper():
            repl = CONTRACTIONS[low]
            text = text[:m.start()] + repl + text[m.end():]
            changes.append(f"[Contraction] {m.group(1)} → {repl}")
            n += 1

    # Doubled words
    for m in list(re.finditer(r"\b(\w+)\s+\1\b", text, re.IGNORECASE)):
        new = re.sub(re.escape(m.group(0)), m.group(1), text, count=1, flags=re.IGNORECASE)
        if new != text:
            changes.append(f"[Doubled] '{m.group(1)}'")
            text, n = new, n + 1

    # Pleonasms
    for pat, repl in PLEONASMS.items():
        new, k = re.subn(pat, repl, text, flags=re.IGNORECASE)
        if k:
            changes.append(f"[Pleonasm] '{pat}' → '{repl}' ({k}×)")
            text, n = new, n + k

    # ── POST-FIX CLEANUPS ─────────────────────────────────────
    # Fix artifacts caused by sequential pattern replacements

    # "is will" → "will"  (going to→will ran after contraction fix)
    text = re.sub(r'\bis\s+will\b',      'will',  text, flags=re.IGNORECASE)

    # "will will" → "will"  (double will from chained replacements)
    text = re.sub(r'\bwill\s+will\b',   'will',  text, flags=re.IGNORECASE)

    # "is it is" → "is"    (looks like→is + it's→it is chained)
    text = re.sub(r'\bis\s+it\s+is\b',  'is',    text, flags=re.IGNORECASE)

    # "that is it is" → "that is"
    text = re.sub(r'\bthat\s+is\s+it\s+is\b', 'that is', text, flags=re.IGNORECASE)

    # "is is" → "is"       (double is from two replacements)
    text = re.sub(r'\bis\s+is\b',       'is',    text, flags=re.IGNORECASE)

    # "it is will" → "it will"
    text = re.sub(r'\bit\s+is\s+will\b','it will', text, flags=re.IGNORECASE)

    # "There is is" → "There is"
    text = re.sub(r'\bThere\s+is\s+is\b','There is', text, flags=re.IGNORECASE)

    # "A a " → "A "   (article duplication)
    text = re.sub(r'\bA\s+a\s+',        'A ',    text)
    text = re.sub(r'\ba\s+a\s+',        'a ',    text)

    # "The The" → "The"
    text = re.sub(r'\bThe\s+The\b',     'The',   text, flags=re.IGNORECASE)

    # Remove orphan punctuation "stop ." → "stop."
    text = re.sub(r'\s+\.',             '.',     text)
    text = re.sub(r'\s+,',             ',',     text)

    # Catch any remaining doubled words
    text = re.sub(r'\b(\w+)\s+\1\b',
                  lambda m: m.group(1), text, flags=re.IGNORECASE)

    # Final space cleanup
    text = re.sub(r" {2,}", " ", text).strip()

    # Capitalise sentences
    text = fix_caps(text)
    return text, n, changes


# ═══════════════════════════════════════════════════════════════
# 6. ISSUE DETECTION (diagnostic)
# ═══════════════════════════════════════════════════════════════

def detect_issues(text: str, sents: List[str]) -> List[Dict]:
    issues = []

    # Grammar patterns
    for pat, repl, label in _GRAMMAR_PATTERNS:
        try:
            for m in re.finditer(pat, text):
                bad = m.group(0)
                try:
                    sugg = m.expand(repl) if isinstance(repl,str) else repl(m)
                except Exception:
                    sugg = "(auto-fix)"
                issues.append({"type":"grammar","bad":bad,"suggestion":sugg,"rule":label})
        except Exception:
            pass

    # Missing apostrophe contractions
    for m in re.finditer(r"\b([A-Za-z]+)\b", text):
        low = m.group(1).lower()
        if low in CONTRACTIONS:
            issues.append({"type":"contraction","bad":m.group(1),
                           "suggestion":CONTRACTIONS[low]})

    # Doubled words
    for m in re.finditer(r"\b(\w+)\s+\1\b", text, re.IGNORECASE):
        issues.append({"type":"doubled word","bad":m.group(0),
                       "suggestion":m.group(1)})

    # a/an misuse
    for m in re.finditer(r"\b(a|an)\s+([A-Za-z]+)", text, re.IGNORECASE):
        art, nxt = m.group(1).lower(), m.group(2).lower()
        sv = nxt[0] in "aeiou"
        if nxt in AN_EXCEPTIONS: sv = True
        elif nxt in A_EXCEPTIONS: sv = False
        correct = "an" if sv else "a"
        if art != correct:
            issues.append({"type":"a/an","bad":m.group(0),
                           "suggestion":f"{correct} {m.group(2)}"})

    # Capitalisation
    for s in sents:
        if s and s[0].isalpha() and not s[0].isupper():
            issues.append({"type":"capitalisation","bad":s[:40],
                           "suggestion":f"capitalize '{s[0]}'"})

    # spaCy SVA
    issues += check_spacy(text)
    # Spell check
    issues += check_spelling(text)

    # Deduplicate by (type, bad)
    seen, unique = set(), []
    for iss in issues:
        key = (iss["type"], iss["bad"])
        if key not in seen:
            seen.add(key); unique.append(iss)
    return unique


# ═══════════════════════════════════════════════════════════════
# 7. LOW CONFIDENCE CHECKER
# ═══════════════════════════════════════════════════════════════

def lc_check(text: str) -> Tuple[List[Dict], str, List[str]]:
    compiled = []
    for block in LOW_CONF:
        cat = block["category"]
        for (pat, reason, sugg) in block["patterns"]:
            try:
                compiled.append({
                    "regex": re.compile(pat, re.IGNORECASE),
                    "category": cat, "reason": reason, "suggestion": sugg,
                })
            except re.error:
                pass

    issues = []
    for entry in compiled:
        for m in entry["regex"].finditer(text):
            issues.append({
                "word": m.group(), "category": entry["category"],
                "reason": entry["reason"], "suggestion": entry["suggestion"],
                "pos": m.start(),
            })

    seen, unique = set(), []
    for iss in sorted(issues, key=lambda x: x["pos"]):
        key = (iss["pos"], iss["word"].lower())
        if key not in seen:
            seen.add(key); unique.append(iss)

    cleaned = text
    for iss in sorted(unique, key=lambda x: x["pos"], reverse=True):
        pat = re.compile(re.escape(iss["word"]), re.IGNORECASE)
        cleaned = pat.sub(iss["suggestion"] if iss["suggestion"] else " ", cleaned, count=1)

    # ── Post-fix cleanups ────────────────────────────────────
    cleaned = re.sub(r'\bis\s+to\s+be\b',      'is',       cleaned, flags=re.IGNORECASE)
    cleaned = re.sub(r'\bwill\s+to\b',          'will',     cleaned, flags=re.IGNORECASE)
    cleaned = re.sub(r'\bis\s+will\b',          'will',     cleaned, flags=re.IGNORECASE)
    cleaned = re.sub(r'\bwill\s+will\b',        'will',     cleaned, flags=re.IGNORECASE)
    cleaned = re.sub(r'\bis\s+it\s+is\b',       'is',       cleaned, flags=re.IGNORECASE)
    cleaned = re.sub(r'\bthat\s+is\s+it\s+is\b','that is',  cleaned, flags=re.IGNORECASE)
    cleaned = re.sub(r'\bis\s+is\b',            'is',       cleaned, flags=re.IGNORECASE)
    cleaned = re.sub(r'\bit\s+is\s+will\b',     'it will',  cleaned, flags=re.IGNORECASE)
    cleaned = re.sub(r'\bA\s+a\s+',             'A ',       cleaned)
    cleaned = re.sub(r'\ba\s+a\s+',             'a ',       cleaned)
    cleaned = re.sub(r'\bThe\s+The\b',          'The',      cleaned, flags=re.IGNORECASE)
    cleaned = re.sub(r'\s+\.',                  '.',        cleaned)
    cleaned = re.sub(r'\s+,',                  ',',        cleaned)
    # Catch any remaining doubled words
    cleaned = re.sub(r'\b(\w+)\s+\1\b',
                     lambda m: m.group(1), cleaned, flags=re.IGNORECASE)
    cleaned = re.sub(r' {2,}', ' ', cleaned).strip()
    cleaned = fix_caps(cleaned)

    cats = list({i["category"] for i in unique})
    return unique, cleaned, cats


