        ]:
            P.append((rf"(?i)\b({s})\s+\b{b}\b",rf"\1 {inf}",f"SVA3: {s} {b}→{inf}"))

    # ── Modal + base form ─────────────────────────────────────
    MODALS = r"(?i)\b(can|could|will|would|shall|should|may|might|must|ought to)"
