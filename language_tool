# 9. REPORT BUILDER
# ═══════════════════════════════════════════════════════════════

def _bar(title, w=70): return f"\n{'─'*w}\n  {title}\n{'─'*w}"
def _top(title, w=70): return f"\n{'═'*w}\n  {title}\n{'═'*w}"


def run_and_report(text: str, source: str = "input",
                   threshold: float = 0.82, use_slm: bool = True) -> Tuple[str, str]:
    W = 72
    lines = [
        "="*W,
        "  WAYMO CAPTION CHECKER — FULL ANALYSIS REPORT",
        "  Pipeline: LT → Rule-based → Diagnostic → Pleonasm →",
        "            Overuse → TF-IDF → ML-dedup → CoEdit SLM → LowConf",
        "="*W,
        f"  Source    : {source}",
        f"  Generated : {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}",
        f"  Threshold : {threshold}",
    ]

    sents = split_sentences(text)
    words = re.findall(r"\b[A-Za-z]+\b", text)
    lines += [
        f"  Chars     : {len(text):,}",
        f"  Words     : {len(words):,}",
        f"  Sentences : {len(sents)}",
        "",
        "  NOTE: LanguageTool (S1) runs FIRST as the primary corrector.",
        "        Rule-based fixer (S2) catches patterns LT may miss.",
    ]

    final = text

    # ── S1: LanguageTool ─────────────────────────────────────
    lines.append(_bar("SECTION 1 — LANGUAGETOOL (Primary — 600+ rules)"))
    lt_corrected, lt_matches, lt_err = languagetool_correct(text)
    if lt_err:
        lines += [
            f"  STATUS: SKIPPED — {lt_err}",
            "  (LanguageTool public API not available;",
            "   Section 2 rule-based fixer still runs.",
            "   Install: pip install language-tool-python)",
        ]
    else:
        final = lt_corrected
        lines.append(f"  Corrections found: {len(lt_matches)}")
        if lt_matches:
            lines.append(f"  {'#':<4} {'Rule':<35} {'Error':<25} Suggestion")
            lines.append(f"  {'─'*4} {'─'*35} {'─'*25} {'─'*20}")
            for i, m in enumerate(lt_matches, 1):
                el   = getattr(m,"error_length",getattr(m,"errorLength",0))
                snip = getattr(m,"matched_text", text[m.offset:m.offset+el])
                sugg = m.replacements[0] if m.replacements else "(delete)"
                rule = getattr(m,"rule_id",getattr(m,"ruleId","UNKNOWN"))
                lines.append(f"  {i:<4} {rule:<35} {repr(snip):<25} → {repr(sugg)}")
        lines += [
            "",
            f"  — BEFORE (original) ——",
            f"  {text}",
            "",
            f"  — AFTER  (LanguageTool corrected) ——",
            f"  {lt_corrected}",
            "  STATUS: PASSED",
        ]

    # ── S2: Rule-based ───────────────────────────────────────
    lines.append(_bar("SECTION 2 — RULE-BASED AUTO-FIXER (Fallback — 700+ patterns)"))
    rb_fixed, fix_n, rb_changes = rule_based_fixer(final)
    lines.append(f"  Fixes applied: {fix_n}")
    if rb_changes:
        lines.append(f"  {'#':<4} Change")
        lines.append(f"  {'─'*4} {'─'*60}")
        for i, c in enumerate(rb_changes, 1):
            lines.append(f"  {i:<4} {c}")
        lines += [
            "",
            f"  — BEFORE ——",
            f"  {final}",
            "",
            f"  — AFTER  (rule-based corrected) ——",
            f"  {rb_fixed}",
        ]
    else:
        lines.append("  No additional rule-based fixes needed.")
    lines.append("  STATUS: PASSED")
    final = rb_fixed

    # ── S3: Diagnostic ───────────────────────────────────────
    lines.append(_bar("SECTION 3 — GRAMMAR & SPELLING DIAGNOSTIC"))
    all_issues = detect_issues(text, sents)
    lines.append(f"  Total issues in original text: {len(all_issues)}")
    if all_issues:
        by_type: Dict = {}
        for iss in all_issues:
            by_type.setdefault(iss["type"], []).append(iss)
        for typ, grp in sorted(by_type.items()):
            lines.append(f"\n  [{typ.upper()}] — {len(grp)} issue(s)")
            for iss in grp[:8]:
                lines.append(f"    bad       : '{iss['bad']}'")
                lines.append(f"    suggestion: '{iss['suggestion']}'")
                if "rule" in iss:
                    lines.append(f"    rule      : {iss['rule']}")
    else:
        lines.append("  No diagnostic issues found.")

    # ── S4: Pleonasms ────────────────────────────────────────
    lines.append(_bar("SECTION 4 — PLEONASMS & VERBOSE PHRASES"))
    pleos = find_pleonasms(text)
    if not pleos:
        lines.append("  None found.")
    else:
        lines.append(f"  {len(pleos)} found:")
        for p, b in pleos:
            lines.append(f"    '{p}' → '{b}'")

    # ── S5: Overused words ───────────────────────────────────
    lines.append(_bar("SECTION 5 — OVERUSED WORDS (>2 occurrences)"))
    overused = find_overused(text)
    if not overused:
        lines.append("  None found.")
    else:
        lines.append(f"  {'Word':<20} Count")
        lines.append(f"  {'─'*20} ─────")
        for w, c in overused:
            lines.append(f"  {w:<20} {c}")

    # ── S6: TF-IDF ───────────────────────────────────────────
    lines.append(_bar("SECTION 6 — NEAR-DUPLICATE SENTENCES (TF-IDF)"))
    dupes = tfidf_dupes(sents, thresh=0.45)
    if not dupes:
        lines.append(f"  {len(sents)} sentence(s) — no near-duplicates found.")
        for i, s in enumerate(sents, 1):
            lines.append(f"    {i}. {s}")
    else:
        for score, s1, s2 in dupes[:5]:
            lines.append(f"\n  Similarity {score:.2f}:")
            lines.append(f"    A: {s1[:100]}")
            lines.append(f"    B: {s2[:100]}")

    # ── S7: ML dedup ─────────────────────────────────────────
    lines.append(_bar("SECTION 7 — SEMANTIC DEDUPLICATION (ML sentence-transformer)"))
    ml_cleaned, ml_removed = ml_dedup(final, thresh=threshold)
    if not ml_removed:
        lines.append("  No redundant sentences found.")
        lines.append("  (Install sentence-transformers for ML dedup support)")
        lines.append("  STATUS: PASSED")
    else:
        lines.append(f"  Removed {len(ml_removed)} redundant sentence(s):")
        for r in ml_removed:
            lines.append(f"    • {r}")
        lines += [f"\n  Cleaned text:\n  {ml_cleaned}", "  STATUS: PASSED"]
        final = ml_cleaned

    # ── S8: CoEdit SLM ───────────────────────────────────────
    lines.append(_bar("SECTION 8 — COEDIT-LARGE SLM (grammarly/coedit-large)"))
    if use_slm:
        slm_out, slm_pairs, slm_ok = coedit_correct(final)
        if slm_ok:
            lines += [
                "  Model  : grammarly/coedit-large (T5-based GEC)",
                f"  Changes: {len(slm_pairs)} sentence(s) corrected",
            ]
            for i, (orig, fixed) in enumerate(slm_pairs, 1):
                lines += [f"\n  — #{i} —", f"  BEFORE: {orig}", f"  AFTER : {fixed}"]
            if not slm_pairs:
                lines.append("  No further corrections — text already clean.")
            lines.append("  STATUS: PASSED")
            final = slm_out
        else:
            lines += [
                "  STATUS: SKIPPED — model not available.",
                "  Install: pip install transformers torch sentencepiece",
                "  Download: python -c \"from transformers import pipeline; pipeline('text2text-generation', model='grammarly/coedit-large')\"",
            ]
    else:
        lines += [
            "  STATUS: SKIPPED (--no-slm flag set)",
            "  Remove --no-slm to enable CoEdit SLM grammar correction.",
        ]

    # ── S9: Low confidence ───────────────────────────────────
    lines.append(_bar("SECTION 9 — LOW CONFIDENCE WORDS (Waymo AV-specific, 20 categories)"))
    lc_issues, lc_fixed, lc_cats = lc_check(final)
    lines.append(f"  Issues found : {len(lc_issues)}")
    if lc_cats:
        lines.append(f"  Categories   : {', '.join(lc_cats)}")
    if lc_issues:
        lines.append(f"\n  {'#':<4} {'Category':<25} {'Found':<30} Fix")
        lines.append(f"  {'─'*4} {'─'*25} {'─'*30} {'─'*20}")
        for i, iss in enumerate(lc_issues, 1):
            fix = f"→ '{iss['suggestion']}'" if iss["suggestion"] else "→ REMOVE"
            lines.append(f"  {i:<4} {iss['category']:<25} '{iss['word']:<28}' {fix}")
            lines.append(f"       Reason: {iss['reason']}")
    final = lc_fixed

    # ── Final text ───────────────────────────────────────────
    lines += [
        "",
        "="*W,
        "  FINAL CORRECTED TEXT",
        "="*W,
        "",
        f"  ORIGINAL  : {text}",
        "",
        f"  CORRECTED : {final}",
        "",
        "="*W,
        "  SUMMARY",
        "="*W,
        f"  S1 LanguageTool       : {'N/A (not installed)' if lt_err else str(len(lt_matches))+' corrections'}",
        f"  S2 Rule-based fixes   : {fix_n} applied",
        f"  S3 Diagnostic issues  : {len(all_issues)} found",
        f"  S4 Pleonasms          : {len(pleos)} found",
        f"  S5 Overused words     : {len(overused)} found",
        f"  S6 TF-IDF near-dupes  : {len(dupes)} pairs found",
        f"  S7 ML redundancy      : {len(ml_removed)} sentences removed",
        f"  S8 CoEdit SLM         : {'applied' if use_slm else 'skipped (--no-slm)'}",
        f"  S9 Low confidence     : {len(lc_issues)} issues found & fixed",
        "="*W,
    ]

    return "\n".join(lines), final


