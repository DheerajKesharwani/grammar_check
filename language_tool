# ░░  SECTION 6 — GRAMMAR CHECKER
# ════════════════════════════════════════════════════════════════

class GrammarChecker:

    def __init__(self):
        self._patterns = []
        for entry in _GRAMMAR_PATTERNS:
            pat, repl, label = entry
            try:
                self._patterns.append((re.compile(pat), repl, label))
            except re.error:
                pass
        self._pleonasms = [
            (re.compile(p, re.IGNORECASE), r, "Pleonasm")
            for p, r in PLEONASMS.items()
        ]
        self._word_fixes = [
            (re.compile(p, re.IGNORECASE), r, "Spell/OCR")
            for p, r in _WORD_FIXES.items()
        ]

    def _sentences(self, text: str) -> List[Tuple[int,str]]:
        results = []
        for m in re.finditer(r'[^.!?\n]+[.!?\n]?', text):
            results.append((m.start(), m.group().strip()))
        return results

    def _find_sent(self, pos: int, sents: List[Tuple[int,str]]) -> str:
        for (start, sent) in sents:
            if start <= pos <= start + len(sent):
                return sent
        return ""

    def check(self, text: str) -> Tuple[List[GrammarIssue], str]:
        issues    = []
        corrected = text
        sents     = self._sentences(text)

        # Word fixes first
        for (regex, repl, label) in self._word_fixes:
            for m in regex.finditer(corrected):
                try:
                    new = regex.sub(repl, m.group())
                    if new != m.group():
                        issues.append(GrammarIssue(m.group(), new, label, m.start(),
                                                   self._find_sent(m.start(), sents)))
                except Exception: pass
            try: corrected = regex.sub(repl, corrected)
            except Exception: pass

        # Contractions
        for m in re.finditer(r"\b([A-Za-z]+)\b", corrected):
            low = m.group(1).lower()
            if low in CONTRACTIONS and not m.group(1)[0].isupper():
                fix = CONTRACTIONS[low]
                issues.append(GrammarIssue(m.group(1), fix,
                    f"Contraction: {m.group(1)} → {fix}", m.start(),
                    self._find_sent(m.start(), sents)))

        # Doubled words
        for m in re.finditer(r"\b(\w+)\s+\1\b", corrected, re.IGNORECASE):
            issues.append(GrammarIssue(m.group(0), m.group(1),
                f"Doubled word: '{m.group(1)}'", m.start(),
                self._find_sent(m.start(), sents)))

        # All grammar patterns
        for (regex, repl, label) in self._patterns:
            for m in regex.finditer(corrected):
                try:
                    new = m.expand(repl) if isinstance(repl,str) else repl(m)
                    if new.strip() != m.group().strip():
                        issues.append(GrammarIssue(m.group(), new, label, m.start(),
                                                   self._find_sent(m.start(), sents)))
                except Exception: pass
            try:
                corrected = regex.sub(repl, corrected)
            except Exception: pass

        # Deduplicate
        seen, unique = set(), []
        for issue in sorted(issues, key=lambda x: x.position):
            key = (issue.position, issue.original.lower())
            if key not in seen:
                seen.add(key); unique.append(issue)

        # Cleanup
        corrected = re.sub(r' {2,}', ' ', corrected).strip()
        return unique, corrected


# ════════════════════════════════════════════════════════════════
# ░░  SECTION 7 — LOW CONFIDENCE CHECKER
# ════════════════════════════════════════════════════════════════

class LowConfidenceChecker:

    def __init__(self):
        self._compiled = []
        for cat_block in LOW_CONFIDENCE_PATTERNS:
            cat = cat_block["category"]
            for (pattern, reason, suggestion) in cat_block["patterns"]:
                try:
                    self._compiled.append({
                        "regex": re.compile(pattern, re.IGNORECASE),
                        "category": cat, "reason": reason, "suggestion": suggestion,
                    })
                except re.error: pass

    def _sentences(self, text: str) -> List[Tuple[int,str]]:
        results = []
        for m in re.finditer(r'[^.!?\n]+[.!?\n]?', text):
            results.append((m.start(), m.group().strip()))
        return results

    def check(self, text: str) -> Tuple[List[LCIssue], str, List[str]]:
        issues    = []
        sentences = self._sentences(text)

        for entry in self._compiled:
            for match in entry["regex"].finditer(text):
                pos = match.start()
                sentence = text
                for (start, sent) in sentences:
                    if start <= pos <= start + len(sent):
                        sentence = sent; break
                issues.append(LCIssue(
                    word_found = match.group(), category = entry["category"],
                    reason = entry["reason"], suggestion = entry["suggestion"],
                    position = pos, sentence = sentence,
                ))

        seen, unique = set(), []
        for issue in sorted(issues, key=lambda x: x.position):
            key = (issue.position, issue.word_found.lower())
            if key not in seen:
                seen.add(key); unique.append(issue)

        cleaned = text
        for issue in sorted(unique, key=lambda x: x.position, reverse=True):
            pat = re.compile(re.escape(issue.word_found), re.IGNORECASE)
            cleaned = pat.sub(issue.suggestion if issue.suggestion else " ", cleaned, count=1)

        cleaned = re.sub(r'\bis\s+to\s+be\b', 'is', cleaned, flags=re.IGNORECASE)
        cleaned = re.sub(r'\bwill\s+to\b',    'will', cleaned, flags=re.IGNORECASE)
        cleaned = re.sub(r' {2,}',             ' ',   cleaned)
        cleaned = cleaned.strip()

        cats = list({i.category for i in unique})
        return unique, cleaned, cats


